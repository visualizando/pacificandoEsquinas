# Copiar a .env y completar. No versionar .env con claves reales.

# Token de Mapbox para basemap satelital en web/ y report/ (opcional; sin esto se usa un basemap raster libre)
MAPBOX_TOKEN=

# Google Static Street View API key para imágenes en las fichas (opcional; sin esto las fichas quedan sin imagen street view)
STREETVIEW_API_KEY=
